{
	"name": "SCH_NurseCall_InterCall_Export_Daily",
	"properties": {
		"description": "Exports data from the InterCall data on Transform for the previous day and triggers the NurseCall-SharePoint-Upload Logic app to execute, passing paramters to it to allow it to retrieve the exported file, created the directory if needed and create a copy of the file there",
		"annotations": [],
		"runtimeState": "Started",
		"pipelines": [
			{
				"pipelineReference": {
					"referenceName": "PL_NurseCall_InterCall_Export",
					"type": "PipelineReference"
				},
				"parameters": {
					"ExportType": "Daily",
					"ReportDate": "@formatDateTime(addDays(trigger().scheduledTime, -1), 'yyyy-MM-dd')",
					"Home": "Silvermere"
				}
			}
		],
		"type": "ScheduleTrigger",
		"typeProperties": {
			"recurrence": {
				"frequency": "Day",
				"interval": 1,
				"startTime": "2026-07-17T08:12:00",
				"timeZone": "GMT Standard Time",
				"schedule": {
					"minutes": [
						30
					],
					"hours": [
						7
					]
				}
			}
		}
	}
}